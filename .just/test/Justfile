set working-directory := "../.."

[private]
default:
    just --list --justfile {{source_file()}}

# Run CLI unit tests
cli:
    go test -race -count=1 ./apps/... ./libs/...

# Run end-to-end tests (compiles the binary and exercises the CLI per-platform)
e2e:
    go test -count=1 -timeout=5m ./tests/e2e/...

# Run everything
all: cli e2e
